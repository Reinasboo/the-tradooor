# ═══════════════════════════════════════════════════════════════════════════
# The Tradooor - Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials
# Never commit .env to version control!

# ═══════════════════════════════════════════════════════════════════════════
# API & Blockchain Configuration
# ═══════════════════════════════════════════════════════════════════════════

# GMGN API Key (from https://api.gmgn.ai)
GMGN_API_KEY=gmgn_sk_xxxxxxxxxxxxx

# GMGN API Base URL (default)
GMGN_API_BASE_URL=https://api.gmgn.ai

# Solana RPC URL
# Public (rate-limited): https://api.mainnet-beta.solana.com
# Recommended: https://helius.dev or https://quicknode.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Solana Wallet Private Key (base58 format)
# WARNING: Never use a wallet with significant funds!
SOLANA_WALLET_PRIVATE_KEY=your_private_key_here

# ═══════════════════════════════════════════════════════════════════════════
# Trading Filters (Prevents bad trades)
# ═══════════════════════════════════════════════════════════════════════════

# Minimum liquidity in SOL to consider
MIN_LIQUIDITY_SOL=10

# Maximum 24h price increase % (avoid over-hyped tokens)
MAX_PRICE_INCREASE_PCT=500

# Minimum holder count for community validation
MIN_HOLDER_COUNT=50

# Minimum 24h trading volume
MIN_VOLUME_24H=1000

# ═══════════════════════════════════════════════════════════════════════════
# Risk Management (Kelly Criterion - Phase 1)
# ═══════════════════════════════════════════════════════════════════════════

# Starting portfolio size ($)
PORTFOLIO_SIZE=10000

# Kelly fraction (0.25 = quarter Kelly for crypto volatility)
# Lower = more conservative, Higher = more aggressive
KELLY_FRACTION=0.25

# Maximum position size as % of portfolio
# Limits individual trade exposure
MAX_POSITION_SIZE_PCT=5

# Maximum portfolio drawdown % before emergency stop
# Safety mechanism during losing streaks
MAX_DRAWDOWN_PCT=30

# ═══════════════════════════════════════════════════════════════════════════
# Trading Mode
# ═══════════════════════════════════════════════════════════════════════════

# Dry-run mode: Simulate trades without executing
# true = test mode (recommended for initial setup)
# false = ready for trading
ENABLE_DRY_RUN=true

# Auto-trading: Execute trades automatically
# false = signals only, requires manual approval
# true = full automation
ENABLE_AUTO_TRADING=false

# Amount per trade in SOL
# Start small: 0.01-0.1 SOL
# Scale up: 0.5-2.0 SOL after testing
TRADING_AMOUNT_SOL=0.1

# ═══════════════════════════════════════════════════════════════════════════
# Notifications (Optional)
# ═══════════════════════════════════════════════════════════════════════════

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID (your Telegram user ID)
TELEGRAM_CHAT_ID=

# Discord Webhook URL (create in server settings)
DISCORD_WEBHOOK_URL=

# ═══════════════════════════════════════════════════════════════════════════
# Logging & Debugging
# ═══════════════════════════════════════════════════════════════════════════

# Log level: trace|debug|info|warn|error
LOG_LEVEL=info

# Log all trade activity
LOG_TRADES=true

# Save logs to file
LOG_FILE=true

# ═══════════════════════════════════════════════════════════════════════════
# Advanced Configuration (Optional)
# ═══════════════════════════════════════════════════════════════════════════

# Backtest parameters
BACKTEST_YEARS=1
BACKTEST_START_BALANCE=10000

# ML prediction confidence threshold (0-1)
ML_CONFIDENCE_THRESHOLD=0.6

# Sentiment analysis weights (sum must = 1.0)
SENTIMENT_ONCHAIN_WEIGHT=0.5
SENTIMENT_DISCORD_WEIGHT=0.25
SENTIMENT_TWITTER_WEIGHT=0.15

# MEV protection
ENABLE_MEV_PROTECTION=true
JITO_TIP_SOL=0.005

# Multi-wallet execution
ENABLE_MULTI_WALLET=false
WALLET_COUNT=1

# ═══════════════════════════════════════════════════════════════════════════
# Setup Instructions
# ═══════════════════════════════════════════════════════════════════════════

# 1. Get GMGN API Key:
#    - Visit https://api.gmgn.ai
#    - Sign up / log in
#    - Generate API key
#    - Copy to GMGN_API_KEY

# 2. Get Solana RPC URL:
#    - Option A: Use free public RPC (rate-limited)
#    - Option B: Sign up at https://helius.dev (recommended)
#    - Option C: Sign up at https://quicknode.com (recommended)

# 3. Get Wallet Private Key:
#    - Create new wallet (recommended for trading bot)
#    - Export private key from Phantom, Solflare, etc.
#    - Format should be base58 string
#    - WARNING: Never use main wallet!

# 4. Test Configuration:
#    npm run build      # Verify no compilation errors
#    npm test           # Run test suite
#    npm run dev        # Start bot in dry-run mode

# ═══════════════════════════════════════════════════════════════════════════
# Configuration Profiles
# ═══════════════════════════════════════════════════════════════════════════

# Conservative Profile (Low Risk):
# MIN_LIQUIDITY_SOL=50
# MAX_PRICE_INCREASE_PCT=200
# MIN_HOLDER_COUNT=200
# KELLY_FRACTION=0.1
# MAX_POSITION_SIZE_PCT=2
# MAX_DRAWDOWN_PCT=15
# ENABLE_DRY_RUN=true
# TRADING_AMOUNT_SOL=0.01

# Aggressive Profile (High Risk):
# MIN_LIQUIDITY_SOL=5
# MAX_PRICE_INCREASE_PCT=1000
# MIN_HOLDER_COUNT=20
# KELLY_FRACTION=0.5
# MAX_POSITION_SIZE_PCT=10
# MAX_DRAWDOWN_PCT=50
# ENABLE_AUTO_TRADING=true
# TRADING_AMOUNT_SOL=1.0

# Balanced Profile (Recommended):
# MIN_LIQUIDITY_SOL=10
# MAX_PRICE_INCREASE_PCT=500
# MIN_HOLDER_COUNT=50
# KELLY_FRACTION=0.25
# MAX_POSITION_SIZE_PCT=5
# MAX_DRAWDOWN_PCT=30
# ENABLE_DRY_RUN=true
# TRADING_AMOUNT_SOL=0.1
